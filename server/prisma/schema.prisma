generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  username  String
  createdAt DateTime @default(now()) @map("createdAt")

  trades               Trade[]
  spaces               Space[]
  plans                PlanRule[]
  riskRules            RiskRule[]
  templateTypes        TemplateType[]
  templates            Template[]
  calendarEvents       CalendarEvent[]
  calendarDrawings     CalendarDrawing[]
  drawingBoardDrawings DrawingBoardDrawing[]
  scheduleTasks        ScheduleTask[]
  settings             Setting[]

  @@map("users")
}

model Space {
  id        String   @id @default(uuid())
  userId    String   @map("userId")
  name      String
  createdAt DateTime @default(now()) @map("createdAt")

  user                 User                  @relation(fields: [userId], references: [id])
  trades               Trade[]
  plans                PlanRule[]
  riskRules            RiskRule[]
  templateTypes        TemplateType[]
  templates            Template[]
  calendarEvents       CalendarEvent[]
  calendarDrawings     CalendarDrawing[]
  drawingBoardDrawings DrawingBoardDrawing[]
  scheduleTasks        ScheduleTask[]
  settings             Setting[]

  @@map("spaces")
}

model Trade {
  id                String   @id @default(uuid())
  userId            String   @map("userId")
  spaceId           String   @map("spaceId")
  instrument        String
  side              String
  strategy          String
  entryPrice        Float    @map("entryPrice")
  exitPrice         Float    @map("exitPrice")
  quantity          Float
  entryTime         DateTime @map("entryTime")
  exitTime          DateTime @map("exitTime")
  profitLoss        Float    @map("profitLoss")
  profitLossPercent Float    @map("profitLossPercent")
  status            String   @default("pending")
  tags              Json     @default("[]")
  notes             String?
  screenshots       Json     @default("[]")
  emotion           String   @default("neutral")
  planData          Json     @default("[]") @map("planData")
  setupData         Json     @default("[]") @map("setupData")

  user  User  @relation(fields: [userId], references: [id])
  space Space @relation(fields: [spaceId], references: [id])

  plans TradePlanRule[]

  @@map("trades")
}

model TradePlanRule {
  tradeId  String       @map("tradeId")
  userId   String       @map("userId")
  spaceId  String       @map("spaceId")
  template PlanTemplate

  trade Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  plan  PlanRule @relation(fields: [userId, spaceId, template], references: [userId, spaceId, template], onDelete: Cascade)

  @@id([tradeId, userId, spaceId, template])
  @@map("trade_plan_rules")
}

enum PlanTemplate {
  checklist
  coreRules
  tradingSetup
  mistakes
  identity
}

model PlanRule {
  userId    String       @map("userId")
  spaceId   String       @map("spaceId")
  template  PlanTemplate
  content   Json         @default("[]")
  updatedAt DateTime     @updatedAt @map("updatedAt")

  user   User            @relation(fields: [userId], references: [id])
  space  Space           @relation(fields: [spaceId], references: [id])
  trades TradePlanRule[]

  @@id([userId, spaceId, template])
  @@map("plan_rules")
}

model TemplateType {
  id        String   @id @default(uuid())
  userId    String   @map("userId")
  spaceId   String   @map("spaceId")
  name      String
  color     String   @default("#22c55e")
  createdAt DateTime @default(now()) @map("createdAt")

  user      User       @relation(fields: [userId], references: [id])
  space     Space      @relation(fields: [spaceId], references: [id])
  templates Template[]

  @@unique([userId, spaceId, name])
  @@map("template_types")
}

model Template {
  id         String   @id @default(uuid())
  userId     String   @map("userId")
  spaceId    String   @map("spaceId")
  name       String
  typeId     String?  @map("typeId")
  isAttached Boolean  @default(false) @map("isAttached")
  createdAt  DateTime @default(now()) @map("createdAt")
  updatedAt  DateTime @updatedAt @map("updatedAt")

  user  User           @relation(fields: [userId], references: [id])
  space Space          @relation(fields: [spaceId], references: [id])
  type  TemplateType?  @relation(fields: [typeId], references: [id])
  items TemplateItem[]

  @@map("templates")
}

model TemplateItem {
  id         String   @id @default(uuid())
  templateId String   @map("templateId")
  type       String
  label      String
  value      String?
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("createdAt")
  updatedAt  DateTime @updatedAt @map("updatedAt")

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_items")
}

model CalendarEvent {
  id        String   @id @default(uuid())
  userId    String   @map("userId")
  spaceId   String   @map("spaceId")
  date      String // yyyy-MM-dd format
  title     String
  content   String   @default("")
  createdAt DateTime @default(now()) @map("createdAt")
  updatedAt DateTime @updatedAt @map("updatedAt")

  user  User  @relation(fields: [userId], references: [id])
  space Space @relation(fields: [spaceId], references: [id])

  @@index([userId, spaceId, date])
  @@map("calendar_events")
}

model CalendarDrawing {
  id        String   @id @default(uuid())
  userId    String   @map("userId")
  spaceId   String   @map("spaceId")
  date      String
  title     String   @default("Drawing")
  sceneData Json     @default("{}")
  createdAt DateTime @default(now()) @map("createdAt")
  updatedAt DateTime @updatedAt @map("updatedAt")

  user  User  @relation(fields: [userId], references: [id])
  space Space @relation(fields: [spaceId], references: [id])

  @@index([userId, spaceId, date])
  @@map("calendar_drawings")
}

model DrawingBoardDrawing {
  id        String   @id @default(uuid())
  userId    String   @map("userId")
  spaceId   String   @map("spaceId")
  date      String
  title     String   @default("Drawing")
  sceneData Json     @default("{}")
  createdAt DateTime @default(now()) @map("createdAt")
  updatedAt DateTime @updatedAt @map("updatedAt")

  user  User  @relation(fields: [userId], references: [id])
  space Space @relation(fields: [spaceId], references: [id])

  @@index([userId, spaceId, date])
  @@map("drawing_board_drawings")
}

model RiskRule {
  id        String   @id @default(uuid())
  userId    String   @map("userId")
  spaceId   String   @map("spaceId")
  name      String
  value     Float
  unit      String   @default("USD")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("createdAt")
  updatedAt DateTime @updatedAt @map("updatedAt")

  user  User  @relation(fields: [userId], references: [id])
  space Space @relation(fields: [spaceId], references: [id])

  @@map("risk_rules")
}

model ScheduleTask {
  id            String   @id @default(uuid())
  userId        String   @map("userId")
  spaceId       String   @map("spaceId")
  title         String
  time          String?
  timeEnd       String?
  taskDate      String   // yyyy-MM-dd
  completed     Boolean  @default(false)
  description   String?
  type          String   @default("analysis")
  repeatGroupId String?
  reminder      Int?     // minutes before
  reminderSent  Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("createdAt")
  updatedAt     DateTime @updatedAt @map("updatedAt")

  user  User  @relation(fields: [userId], references: [id])
  space Space @relation(fields: [spaceId], references: [id])

  @@index([userId, spaceId, taskDate])
  @@map("schedule_tasks")
}

model Notification {
  id          String   @id @default(uuid())
  userId      String   @map("userId")
  spaceId     String   @map("spaceId")
  type        String
  category    String
  title       String
  description String
  status      String   @default("unread")
  linkPath    String?  @map("linkPath")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("createdAt")
  updatedAt   DateTime @updatedAt @map("updatedAt")

  @@index([userId, spaceId])
  @@index([userId, spaceId, status])
  @@map("notifications")
}

model Setting {
  id        String   @id @default(uuid())
  userId    String   @map("userId")
  spaceId   String?  @map("spaceId")
  key       String
  value     Json     @default("{}")
  createdAt DateTime @default(now()) @map("createdAt")
  updatedAt DateTime @updatedAt @map("updatedAt")

  user  User   @relation(fields: [userId], references: [id])
  space Space? @relation(fields: [spaceId], references: [id])

  @@index([userId, spaceId, key])
  @@map("settings")
}
