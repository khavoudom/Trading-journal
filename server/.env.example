DATABASE_URL=postgresql://postgres:<password>@localhost:5432/trading_journal
JWT_SECRET=change-me

# Gmail SMTP for email notifications
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=your-app-password

# Optional: enables shared authorization caching across server instances
# REDIS_URL=redis://localhost:6379

# Yahoo Finance API base URL
# YAHOO_FINANCE_BASE_URL=https://query1.finance.yahoo.com/v8/finance/chart

# Logging — multi-driver configuration
# LOG_DRIVERS=console,file,sentry        # comma-separated driver list (default: console,file)
# LOG_LEVEL=info                         # debug | info | warn | error (default: info)
# LOG_DIR=logs                           # file driver directory (default: logs)
# LOG_FILE=app.log                       # file driver filename (default: app.log)
# SENTRY_DSN=                            # required for sentry driver